# =====================================================
# 환경변수 템플릿 — `.env`로 복사 후 본인 토큰 입력
#   cp .env.example .env
# =====================================================

# HuggingFace 토큰 (필수)
# - meta-llama/Llama-3.1-8B-Instruct 라이선스 동의 후 발급
# - https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (선택) Weights & Biases — MoE 학습 로깅에 사용
WANDB_API_KEY=

# (선택) HF Hub 캐시 위치 (기본: ~/.cache/huggingface)
# HF_HOME=/path/to/cache

# (선택) sae_lens 캐시 위치
# SAE_LENS_CACHE_DIR=/path/to/sae-cache
